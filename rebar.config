%% -*- mode:erlang -*-
{erl_opts, [debug_info]}.
{project_plugins, [rebar3_proper]}.

{deps,
 [ {gproc, {git, "https://github.com/uwiger/gproc", {tag, "1.1.0"}}}
 , {snabbkaffe, {git, "https://github.com/kafka4beam/snabbkaffe", {tag, "1.0.10"}}}
 , {optvar, {git, "https://github.com/emqx/optvar", {tag, "1.0.5"}}}
 %% Discovery:
 , {jsone, "1.9.0"}
 , {eetcd, {git, "https://github.com/zhongwencool/eetcd", {tag, "v0.6.0"}}}
 , {hackney, {git, "https://github.com/emqx/hackney.git", {tag, "1.18.1-1"}}}
 %% Testing:
 , {meck, "1.0.0"}
 , {familiar, {git, "https://github.com/ieQu1/familiar.git", {tag, "0.1.1"}}}
 ]}.

{dialyzer,
 [ {plt_extra_aps, [gproc, familiar]}
 ]}.

{profiles,
 [ {concuerror,
    [{overrides,
      [ {add, snabbkaffe,
         [{erl_opts, [{d, 'CONCUERROR'}]}]}
      ]}
    ]}
 ]}.

{xref_checks,
 [ undefined_function_calls
 , undefined_functions
 , locals_not_used
 , deprecated_function_calls
 , deprecated_functions
 ]}.
